# Copy this file to .env.local and fill in the values before running the app.
# Do not commit .env.local to source control.

NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username?embed_domain=localhost&embed_type=Inline

# Optional: only needed for server-only Sanity reads of private or draft content.
# SANITY_API_READ_TOKEN=your-sanity-read-token
